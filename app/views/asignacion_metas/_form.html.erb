<%= simple_form_for(@asignacion_meta,
                    url: asignacion_meta_path(@meta),
                    method: :patch) do |f| %>

  <div class="card shadow-sm border-0 rounded-4">

    <!-- Header -->
    <div class="card-header bg-dark text-white py-3 rounded-top-4">
      <h4 class="mb-0">
        <i class="bi bi-diagram-3-fill me-2"></i>
        Asignación de Metas a Unidades
      </h4>
    </div>

    <!-- Body -->
    <div class="card-body p-4">

      <%= f.error_notification %>

      <% if flash[:alert] %>
        <div class="alert alert-danger">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <!-- Meta -->
      <div class="row mb-4">
        <div class="col-lg-6">

          <%= f.input :meta_id,
            collection: Meta.order(:nombre).map { |m|
              [
                "#{m.nombre} (cada #{m.cantidad_meta} km)",
                m.id
              ]
            },
            label: "Meta a Asignar",
            prompt: "Seleccione una meta",
            input_html: {
              class: "form-select"
            } %>

        </div>
      </div>

      <hr>

      <!-- Barra superior -->
      <div class="row align-items-center mb-3">

        <div class="col-md-4">

          <div class="form-check form-switch">
            <input type="checkbox"
                   id="seleccionar_todas"
                   class="form-check-input">

            <label for="seleccionar_todas"
                   class="form-check-label fw-semibold">

              Seleccionar todas las unidades

            </label>
          </div>

        </div>

        <div class="col-md-8">

          <div class="input-group">
            <span class="input-group-text">
              <i class="bi bi-search"></i>
            </span>

            <input type="text"
                   id="buscar_unidad"
                   class="form-control"
                   placeholder="Buscar por código o placa...">
          </div>

        </div>

      </div>

      <!-- Lista -->
      <div class="card border">

        <div class="card-header bg-light">
          <strong>
            <i class="bi bi-truck"></i>
            Unidades Disponibles
          </strong>
        </div>

        <div id="lista_unidades"
             class="card-body p-0"
             style="max-height:500px;overflow-y:auto;">

          <% Unidad.order(:codigo).each do |unidad| %>

            <% marcada =
              defined?(@meta) ?
              @meta.unidad_ids.include?(unidad.id) :
              false %>

            <div class="unidad-item border-bottom p-3 hover-row">

              <div class="form-check">

                <%= check_box_tag(
                  "unidad_ids[]",
                  unidad.id,
                  marcada,
                  class: "form-check-input unidad-checkbox",
                  id: "unidad_#{unidad.id}"
                ) %>

                <%= label_tag(
                  "unidad_#{unidad.id}",
                  nil,
                  class: "form-check-label w-100"
                ) do %>

                  <div class="d-flex justify-content-between align-items-center">

                    <div>
                      <strong class="text-primary">
                        <%= unidad.codigo %>
                      </strong>
                    </div>

                    <div>
                      <span class="badge bg-secondary">
                        <%= unidad.placa %>
                      </span>
                    </div>

                  </div>

                <% end %>

              </div>

            </div>

          <% end %>

        </div>

      </div>

    </div>

    <!-- Footer -->
    <div class="card-footer bg-light d-flex justify-content-between">

      <%= link_to asignacion_metas_path,
          class: "btn btn-outline-secondary" do %>

        <i class="bi bi-arrow-left"></i>
        Regresar

      <% end %>

      <%= f.button :submit,
          "Guardar Asignación",
          class: "btn btn-info px-4 text-white" %>

    </div>

  </div>

<% end %>

<script>
document.addEventListener("turbo:load", () => {

  const buscador = document.getElementById("buscar_unidad");
  const seleccionarTodas = document.getElementById("seleccionar_todas");

  if (buscador) {

    buscador.addEventListener("input", function() {

      const texto = this.value.toLowerCase();

      document.querySelectorAll(".unidad-item").forEach(item => {

        const contenido = item.textContent.toLowerCase();

        item.style.display =
          contenido.includes(texto)
            ? ""
            : "none";

      });

    });

  }

  if (seleccionarTodas) {

    seleccionarTodas.addEventListener("change", function() {

      document
        .querySelectorAll(".unidad-checkbox")
        .forEach(check => {
          check.checked = this.checked;
        });

    });

  }

});
</script>