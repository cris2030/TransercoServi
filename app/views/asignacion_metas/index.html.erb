<% content_for :title, "Asignación de Metas" %>

<div class="d-flex justify-content-between align-items-center mb-3">

  <h2 class="fw-semibold mb-0">
    Asignación de Metas
  </h2>

  <%= link_to "Nueva Asignación", new_asignacion_meta_path, class: "btn btn-primary" %>

</div>

<% if notice.present? %>
  <div class="alert alert-success py-2">
    <%= notice %>
  </div>
<% end %>

<div class="card shadow-sm border-0">

  <div class="table-responsive">

    <table class="table table-hover align-middle mb-0">

      <thead class="table-dark">

        <tr>
          <th>Unidad</th>
          <th>Meta</th>
          <th style="width:180px;">Acciones</th>
        </tr>

      </thead>

      <tbody>

        <% @asignacion_metas.each do |asignacion_meta| %>

          <tr>

            <td class="fw-semibold">
              <%= asignacion_meta.unidad.codigo %>
              <br>
              <small class="text-muted">
                <%= asignacion_meta.unidad.placa %>
              </small>
            </td>

            <td>
              <span class="badge"
                    style="background-color:<%= asignacion_meta.meta.color %>; color:#fff; padding:6px 10px;">
                <%= asignacion_meta.meta.nombre %>
              </span>

              <div class="small text-muted mt-1">
                <%= asignacion_meta.meta.kilometraje_inicio %> - 
                <%= asignacion_meta.meta.kilometraje_final %> km
              </div>
            </td>

            <td>

              <div class="d-flex gap-2">

                <%= link_to "Ver",
                    asignacion_meta,
                    class: "btn btn-sm btn-outline-primary" %>

                <%= link_to "Editar",
                    edit_asignacion_meta_path(asignacion_meta),
                    class: "btn btn-sm btn-outline-warning" %>

                <%= button_to "",
                    asignacion_meta,
                    method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    form: { data: { turbo_confirm: "¿Eliminar asignación?" } },
                    value: "🗑" %>

              </div>

            </td>

          </tr>

        <% end %>

      </tbody>

    </table>

  </div>

</div>