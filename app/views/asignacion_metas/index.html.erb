<% content_for :title, "Asignación de Metas" %>

<div class="d-flex justify-content-between align-items-center mb-3">

  <h2 class="fw-semibold mb-0">
    Asignación de Metas
  </h2>

  <%= link_to "Nueva Asignación",
              new_asignacion_meta_path,
              class: "btn btn-primary" %>

</div>

<div class="card shadow-sm border-0">

  <div class="table-responsive">

    <table class="table table-hover align-middle mb-0">

      <thead class="table-dark">

        <tr>
          <th>Meta</th>
          <th>Unidades Asignadas</th>
          <th>Acciones</th>
        </tr>

      </thead>

      <tbody>

        <% @metas.each do |meta| %>

          <tr>

            <td>

              <span class="badge"
                    style="background-color:<%= meta.color %>; color:white;">

                <%= meta.nombre %>

              </span>

            </td>

            <td>

              <span class="badge bg-primary">

                <%= meta.unidades.count %>

              </span>

            </td>

            <td>

              <%= link_to "Editar",
                          edit_asignacion_meta_path(meta.id),
                          class: "btn btn-warning btn-sm" %>

            </td>

          </tr>

        <% end %>

      </tbody>

    </table>

  </div>

</div>