<% content_for :title, "Asignación de Meta" %>

<% if notice.present? %>
  <div class="alert alert-success py-2">
    <%= notice %>
  </div>
<% end %>

<div class="card shadow-sm border-0">

  <!-- HEADER CON COLOR DE META -->
  <div class="card-header text-white d-flex justify-content-between align-items-center"
       style="background-color:<%= @asignacion_meta.meta.color %>">

    <div>
      <h5 class="mb-0">
        Unidad <%= @asignacion_meta.unidad.codigo %>
      </h5>

      <small>
        Placa: <%= @asignacion_meta.unidad.placa %>
      </small>
    </div>

    <span class="badge bg-dark">
      Meta: <%= @asignacion_meta.meta.nombre %>
    </span>

  </div>

  <div class="card-body">

    <div class="row g-3">

      <!-- UNIDAD -->
      <div class="col-md-6">

        <div class="p-3 border rounded bg-light">

          <h6 class="text-muted">Unidad</h6>

          <p class="mb-1">
            <strong>Código:</strong> <%= @asignacion_meta.unidad.codigo %>
          </p>

          <p class="mb-0">
            <strong>Placa:</strong> <%= @asignacion_meta.unidad.placa %>
          </p>

        </div>

      </div>

      <!-- META -->
      <div class="col-md-6">

        <div class="p-3 border rounded bg-light">

          <h6 class="text-muted">Meta Asignada</h6>

          <p class="mb-1">
            <span class="badge"
                  style="background-color:<%= @asignacion_meta.meta.color %>; color:#fff;">
              <%= @asignacion_meta.meta.nombre %>
            </span>
          </p>

          <p class="mb-1">
            <strong>Inicio:</strong>
            <%= number_with_delimiter(@asignacion_meta.meta.kilometraje_inicio) %> km
          </p>

          <p class="mb-0">
            <strong>Final:</strong>
            <%= number_with_delimiter(@asignacion_meta.meta.kilometraje_final) %> km
          </p>

        </div>

      </div>

    </div>

  </div>

</div>

<!-- ACCIONES -->
<div class="mt-3 d-flex gap-2">

  <%= link_to "Editar",
      edit_asignacion_meta_path(@asignacion_meta),
      class: "btn btn-warning" %>

  <%= link_to "Volver",
      asignacion_metas_path,
      class: "btn btn-secondary" %>

  <%= button_to "Eliminar",
      @asignacion_meta,
      method: :delete,
      class: "btn btn-danger",
      form: { data: { turbo_confirm: "¿Seguro que deseas eliminar esta asignación?" } } %>

</div>