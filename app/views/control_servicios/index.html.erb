<h1>Control Servicios</h1>

<div class="d-flex gap-2 mb-3 align-items-center">

  <input type="text"
         id="buscador-unidad"
         class="form-control"
         placeholder="Buscar unidad...">

  <%= button_to "Actualizar",
                actualizar_control_servicios_path,
                method: :post,
                class: "btn btn-primary" %>

</div>
<div class="tabla-control-servicios">
  <table class="table table-bordered table-hover align-middle">

    <thead class="table-dark sticky-header">
      <tr>
        <th onclick="sortTable(0)">Unidad</th>
        <th onclick="sortTable(1)">Último Servicio</th>
        <th onclick="sortTable(2)">Días Recorridos</th>
        <th onclick="sortTable(3)">Km Recorridos</th>
        <th>Meta</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>

    <tbody>

      <% @control_servicios.each do |fila| %>

        <%
          color_fila =
            case fila[:estado]

            when :urgente
              "#f8d7da"

            when :alerta
              "#fff3cd"

            when :cumplido

              case fila[:meta_actual]&.color
              when "red"
                "#f8d7da"
              when "yellow"
                "#fff3cd"
              when "green"
                "#d1e7dd"
              when "orange"
                "#ffe5b4"
              when "purple"
                "#e2d9f3"
              else
                "#d1e7dd"
              end

            else
              ""
            end
        %>

        <tr style="background-color:<%= color_fila %>">

          <td>
            <strong><%= fila[:unidad].codigo %></strong>
          </td>

          <td>
            <% if fila[:ultimo_servicio].present? %>

              <%= link_to servicio_path(fila[:ultimo_servicio]),
                          class: "text-decoration-none" do %>

                <%= fila[:fecha_ultimo_servicio].strftime("%d/%m/%Y") %>
                <%= fila[:hora_ultimo_servicio]&.strftime("%H:%M") %>

              <% end %>

            <% else %>

              -

            <% end %>
          </td>

          <td>
            <%= fila[:dias_recorridos] %>
          </td>

          <td>
            <%= number_with_precision(
                  fila[:km_desde_servicio],
                  precision: 0,
                  delimiter: ","
                ) %>
          </td>

          <td>

            <% if fila[:meta_actual] %>

              <span class="badge"
                    style="background-color:<%= fila[:meta_actual].color %>;">

                <%= fila[:meta_actual].nombre %>

              </span>

              <small class="d-block text-muted">

                <%= number_with_precision(
                      fila[:meta_actual].cantidad_meta,
                      precision: 0,
                      delimiter: ","
                    ) %> km

              </small>

            <% else %>

              <span class="badge bg-secondary">
                Sin Meta
              </span>

            <% end %>

          </td>

          <td>

            <% if fila[:estado] == :urgente %>

              <span class="badge bg-danger">
                URGENTE
              </span>

            <% elsif fila[:estado] == :alerta %>

              <span class="badge bg-warning text-dark">
                ALERTA
              </span>

            <% elsif fila[:estado] == :cumplido %>

              <span class="badge"
                    style="background-color:<%= fila[:meta_actual].color %>;
                          color:white;">

                CUMPLIDO

              </span>

            <% end %>

          </td>

          <td>

            <%= link_to "Registrar Servicio",
                new_servicio_path(
                  unidad_id: fila[:unidad].id,
                  kilometraje: fila[:odometro_actual],
                  return_to: request.fullpath
                ),
                class: "btn btn-primary btn-sm" %>

          </td>

        </tr>

      <% end %>

    </tbody>

  </table>
</div>

<script>
function inicializarBuscador() {

  const input = document.getElementById("buscador-unidad");

  if (!input) return;

  input.addEventListener("input", function () {

    const valor = this.value.toLowerCase();

    document.querySelectorAll("tbody tr").forEach(fila => {

      const unidad = fila.querySelector("td strong");

      if (!unidad) return;

      const texto = unidad.textContent.toLowerCase();

      fila.style.display =
        texto.includes(valor) ? "" : "none";

    });

  });

}
document.addEventListener("turbo:load", inicializarBuscador);
</script>
<script>
let sortDirection = {};

function sortTable(columnIndex) {

  const table = document.querySelector("table");
  const tbody = table.querySelector("tbody");
  const rows = Array.from(tbody.querySelectorAll("tr"));

  const asc = !sortDirection[columnIndex];
  sortDirection[columnIndex] = asc;

  rows.sort((a, b) => {

    let cellA = a.children[columnIndex].innerText.trim();
    let cellB = b.children[columnIndex].innerText.trim();

    // Último Servicio
    if (columnIndex === 1) {

      const partesA = cellA.match(/(\d{2})\/(\d{2})\/(\d{4})/);
      const partesB = cellB.match(/(\d{2})\/(\d{2})\/(\d{4})/);

      const fechaA = partesA
        ? new Date(partesA[3], partesA[2] - 1, partesA[1])
        : new Date(0);

      const fechaB = partesB
        ? new Date(partesB[3], partesB[2] - 1, partesB[1])
        : new Date(0);

      return asc ? fechaA - fechaB : fechaB - fechaA;
    }

    // Días Recorridos
    if (columnIndex === 2) {

      const parseDias = (texto) => {

        const partes = texto.match(/(\d+)m-(\d+)d/);

        if (!partes) return 0;

        return (parseInt(partes[1]) * 30) + parseInt(partes[2]);
      };

      const diasA = parseDias(cellA);
      const diasB = parseDias(cellB);

      return asc ? diasA - diasB : diasB - diasA;
    }

    const numA = parseFloat(cellA.replace(/[^0-9.-]+/g, ""));
    const numB = parseFloat(cellB.replace(/[^0-9.-]+/g, ""));

    if (!isNaN(numA) && !isNaN(numB)) {
      return asc ? numA - numB : numB - numA;
    }

    return asc
      ? cellA.localeCompare(cellB)
      : cellB.localeCompare(cellA);

  });

  rows.forEach(row => tbody.appendChild(row));
}
</script>