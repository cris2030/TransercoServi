<h1>Control Servicios</h1>

<div class="d-flex gap-2 mb-3">
  <%= button_to "Actualizar Datos",
                actualizar_control_servicios_path,
                method: :post,
                class: "btn btn-primary" %>
<!--
  <%= button_to "Enviar Correos",
                enviar_notificaciones_control_servicios_path,
                method: :post,
                class: "btn btn-warning" %> -->
</div>
<div class="tabla-control-servicios">
  <table class="table table-bordered table-hover align-middle">

    <thead class="table-dark sticky-header">
      <tr>
        <th>Unidad</th>
        <th>Último Servicio</th>
        <th>Días Recorridos</th>
        <th>Km Recorridos</th>
        <th>Meta</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>

    <tbody>

      <% @control_servicios.each do |fila| %>

        <%
          color_fila =
            case fila[:estado]

            when :urgente
              "#f8d7da"

            when :alerta
              "#fff3cd"

            when :cumplido

              case fila[:meta_actual]&.color
              when "red"
                "#f8d7da"
              when "yellow"
                "#fff3cd"
              when "green"
                "#d1e7dd"
              when "orange"
                "#ffe5b4"
              when "purple"
                "#e2d9f3"
              else
                "#d1e7dd"
              end

            else
              ""
            end
        %>

        <tr style="background-color:<%= color_fila %>">

          <td>
            <strong><%= fila[:unidad].codigo %></strong>
          </td>

          <td>
            <%= fila[:fecha_ultimo_servicio]&.strftime("%d/%m/%Y") || "-" %>
          </td>

          <td>
            <%= fila[:dias_recorridos] %>
          </td>

          <td>
            <%= number_with_precision(
                  fila[:km_desde_servicio],
                  precision: 0,
                  delimiter: ","
                ) %>
          </td>

          <td>

            <% if fila[:meta_actual] %>

              <span class="badge"
                    style="background-color:<%= fila[:meta_actual].color %>;">

                <%= fila[:meta_actual].nombre %>

              </span>

              <small class="d-block text-muted">

                <%= number_with_precision(
                      fila[:meta_actual].cantidad_meta,
                      precision: 0,
                      delimiter: ","
                    ) %> km

              </small>

            <% else %>

              <span class="badge bg-secondary">
                Sin Meta
              </span>

            <% end %>

          </td>

          <td>

            <% if fila[:estado] == :urgente %>

              <span class="badge bg-danger">
                URGENTE
              </span>

            <% elsif fila[:estado] == :alerta %>

              <span class="badge bg-warning text-dark">
                ALERTA
              </span>

            <% elsif fila[:estado] == :cumplido %>

              <span class="badge"
                    style="background-color:<%= fila[:meta_actual].color %>;
                          color:white;">

                CUMPLIDO

              </span>

            <% end %>

          </td>

          <td>

            <%= link_to "Registrar Servicio",
                new_servicio_path(
                  unidad_id: fila[:unidad].id,
                  kilometraje: fila[:odometro_actual],
                  return_to: request.fullpath
                ),
                class: "btn btn-primary btn-sm" %>

          </td>

        </tr>

      <% end %>

    </tbody>

  </table>
</div>