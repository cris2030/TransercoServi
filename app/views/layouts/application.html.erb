<!DOCTYPE html>
<html>
  <head>
    <title>Control de Servicios</title>
    <%= favicon_link_tag "logo_transerco.png" %>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= javascript_importmap_tags %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body class="bg-light">

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">

      <div class="container">

        <!-- BRAND -->
        <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-semibold" do %>

          <%= image_tag "logo_transerco.png",
              alt: "Logo",
              width: 36,
              height: 36,
              class: "rounded" %>

          <span class="fs-6">
            Control de Servicios
          </span>

        <% end %>

        <!-- TOGGLER -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
          <span class="navbar-toggler-icon"></span>
        </button>

        <!-- MENU -->
        <div class="collapse navbar-collapse" id="navbarContent">

          <!-- LEFT MENU -->
          <ul class="navbar-nav ms-3">

            <li class="nav-item">
              <%= link_to "Odómetro", odometers_path, class: "nav-link" %>
            </li>

            <li class="nav-item">
              <%= link_to "Ubicaciones", locations_path, class: "nav-link" %>
            </li>

            <li class="nav-item">
              <%= link_to "Servicios", control_servicios_path, class: "nav-link" %>
            </li>

          </ul>

          <!-- RIGHT MENU -->
          <ul class="navbar-nav ms-auto align-items-lg-center gap-2">

            <!-- AJUSTES DROPDOWN -->
            <li class="nav-item dropdown">

              <a class="nav-link dropdown-toggle"
                href="#"
                role="button"
                data-bs-toggle="dropdown"
                onclick="return false;">

                ⚙️ Ajustes
              </a>

              <ul class="dropdown-menu dropdown-menu-end shadow-sm">

                <li>
                  <%= link_to "Unidades", unidades_path, class: "dropdown-item" %>
                </li>

                <li>
                  <%= link_to "Metas", metas_path, class: "dropdown-item" %>
                </li>

                <li>
                  <%= link_to "Asignación de Metas", asignacion_metas_path, class: "dropdown-item" %>
                </li>

                <li>
                  <%= link_to "Servicios", servicios_path, class: "dropdown-item" %>
                </li>

                <li>
                  <%= link_to "Notificaciones", meta_notificaciones_path, class: "dropdown-item" %>
                </li>

              </ul>
            </li>

            <!-- USER -->
            <% if user_signed_in? %>

              <li class="nav-item text-light small me-2">
                <%= current_user.email %>
              </li>

              <li class="nav-item">
                <%= button_to "Salir",
                    destroy_user_session_path,
                    method: :delete,
                    class: "btn btn-outline-danger btn-sm rounded-3" %>
              </li>

            <% end %>

          </ul>

        </div>
      </div>
    </nav>

    <!-- CONTENT -->
    <div class="container py-4">
      <%= yield %>
    </div>


  </body>
</html>