
<%= form_with url: meta_notificacion_path(@meta), method: :patch do %>

<div class="card shadow-sm border-0">

  <div class="card-header bg-dark text-white">
    Configuración - <%= @meta.nombre %>
  </div>

  <div class="card-body">

    <input type="text"
           id="buscar_usuario"
           class="form-control mb-3"
           placeholder="Buscar usuario...">

    <div style="max-height:500px; overflow-y:auto;">

      <% @users.each do |user| %>

        <% registros = @config[user.id] || [] %>
        <% estados = registros.map(&:estado) %>

        <div class="border p-3 mb-2 usuario-row">

          <strong><%= user.email %></strong>

          <input type="hidden"
                 name="config[<%= user.id %>][user_id]"
                 value="<%= user.id %>">

          <div class="mt-2">

            <% %w[alerta cumplido urgente].each do |estado| %>

              <label class="me-3">

                <input type="checkbox"
                       name="config[<%= user.id %>][estados][]"
                       value="<%= estado %>"
                       <%= "checked" if estados.include?(estado) %>>

                <%= estado.capitalize %>

              </label>

            <% end %>

          </div>

        </div>

      <% end %>

    </div>

  </div>

  <div class="card-footer">

    <button class="btn btn-success">
      Guardar
    </button>

  </div>

</div>

<% end %>