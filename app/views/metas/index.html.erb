<% content_for :title, "Metas" %>

<div class="container-fluid py-4">

  <!-- Encabezado -->
  <div class="d-flex justify-content-between align-items-center mb-4">

    <div>
      <h2 class="fw-bold mb-0">
        <i class="bi bi-bullseye text-success"></i>
        Metas
      </h2>

      <p class="text-muted mb-0">
        Gestión de metas de mantenimiento y kilometraje.
      </p>
    </div>

    <%= link_to new_meta_path,
          class: "btn btn-success shadow-sm" do %>

      <i class="bi bi-plus-circle"></i>
      Nueva Meta

    <% end %>

  </div>

  <!-- Mensajes -->
  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show">
      <i class="bi bi-check-circle-fill me-2"></i>
      <%= notice %>

      <button type="button"
              class="btn-close"
              data-bs-dismiss="alert"></button>
    </div>
  <% end %>

  <!-- Tarjetas -->
  <div class="row g-4">

    <% @metas.each do |meta| %>

      <div class="col-lg-4 col-md-6">

        <div class="card border-0 shadow-sm h-100 meta-card">

          <!-- Header -->
          <div class="card-header border-0 text-white py-3"
               style="background:<%= meta.color %>;">

            <div class="d-flex justify-content-between align-items-center">

              <h5 class="mb-0 fw-bold">
                <%= meta.nombre %>
              </h5>

              <i class="bi bi-flag-fill fs-4"></i>

            </div>

          </div>

          <!-- Body -->
          <div class="card-body">

            <div class="row text-center">

              <div class="col-4">

                <div class="small text-muted">
                  Meta
                </div>

                <div class="fw-bold fs-5 text-success">
                  <%= number_with_delimiter(meta.cantidad_meta) %>
                </div>

                <small class="text-muted">
                  Km
                </small>

              </div>

              <div class="col-4">

                <div class="small text-muted">
                  Alerta
                </div>

                <div class="fw-bold fs-5 text-warning">
                  <%= number_with_delimiter(meta.alerta_km) %>
                </div>

                <small class="text-muted">
                  Km
                </small>

              </div>

              <div class="col-4">

                <div class="small text-muted">
                  Urgente
                </div>

                <div class="fw-bold fs-5 text-danger">
                  <%= number_with_delimiter(meta.urgente_km) %>
                </div>

                <small class="text-muted">
                  Km
                </small>

              </div>

            </div>

          </div>

          <!-- Footer -->
          <div class="card-footer bg-white border-0">

            <div class="d-flex justify-content-center gap-2">

              <%= link_to meta,
                    class: "btn btn-outline-primary btn-sm" do %>

                <i class="bi bi-eye"></i>
                Ver

              <% end %>

              <%= link_to edit_meta_path(meta),
                    class: "btn btn-outline-warning btn-sm" do %>

                <i class="bi bi-pencil-square"></i>
                Editar

              <% end %>

              <%= link_to meta_path(meta),
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "¿Desea eliminar esta meta?"
                    },
                    class: "btn btn-outline-danger btn-sm" do %>

                <i class="bi bi-trash"></i>
                Eliminar

              <% end %>

            </div>

          </div>

        </div>

      </div>

    <% end %>

  </div>

  <!-- Sin registros -->
  <% if @metas.empty? %>

    <div class="card border-0 shadow-sm mt-4">

      <div class="card-body text-center py-5">

        <i class="bi bi-bullseye text-secondary"
           style="font-size:4rem;"></i>

        <h4 class="mt-3">
          No existen metas registradas
        </h4>

        <p class="text-muted">
          Comience creando su primera meta.
        </p>

        <%= link_to new_meta_path,
              class: "btn btn-success" do %>

          <i class="bi bi-plus-circle"></i>
          Crear Meta

        <% end %>

      </div>

    </div>

  <% end %>

</div>