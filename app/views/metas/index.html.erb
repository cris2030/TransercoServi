<% content_for :title, "Metas" %>

<div class="d-flex justify-content-between align-items-center mb-4">

  <h2 class="fw-semibold mb-0">
    Metas
  </h2>

  <%= link_to "Nueva Meta", new_meta_path, class: "btn btn-primary" %>

</div>

<% if notice.present? %>
  <div class="alert alert-success">
    <%= notice %>
  </div>
<% end %>

<div class="row g-3">

  <% @metas.each do |meta| %>

    <div class="col-md-4">

      <div class="card shadow-sm border-0 h-100">

        <div class="card-header d-flex justify-content-between align-items-center"
             style="background-color:<%= meta.color %>; color:#fff;">

          <strong><%= meta.nombre %></strong>

          <span class="badge bg-dark">
            Nivel <%= meta.nivel_imp %>
          </span>

        </div>

        <div class="card-body">

          <p class="mb-2">
            <strong>Inicio:</strong>
            <%= number_with_delimiter(meta.kilometraje_inicio) %> km
          </p>

          <p class="mb-2">
            <strong>Final:</strong>
            <%= number_with_delimiter(meta.kilometraje_final) %> km
          </p>

          <div class="mt-3 d-flex gap-2">

            <%= link_to "Ver", meta, class: "btn btn-outline-primary btn-sm" %>

            <%= link_to "Editar", edit_meta_path(meta), class: "btn btn-outline-warning btn-sm" %>

          </div>

        </div>

      </div>

    </div>

  <% end %>

</div>