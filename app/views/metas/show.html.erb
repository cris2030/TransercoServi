<div class="card shadow-sm border-0">

  <div class="card-header text-white"
       style="background-color:<%= @meta.color %>">

    <h4 class="mb-0">
      <%= @meta.nombre %>
    </h4>

  </div>

  <div class="card-body">

    <!-- Configuración por Kilómetros -->
    <div class="mb-4">

      <h5 class="border-bottom pb-2">
        🚛 Configuración por Kilómetros
      </h5>

      <div class="row">

        <div class="col-md-4">
          <div class="border rounded p-3 bg-light">
            <small class="text-muted d-block">Meta</small>
            <strong><%= number_with_delimiter(@meta.cantidad_meta) %> Km</strong>
          </div>
        </div>

        <div class="col-md-4">
          <div class="border rounded p-3 bg-warning bg-opacity-10">
            <small class="text-muted d-block">Alerta</small>
            <strong><%= number_with_delimiter(@meta.alerta_km) %> Km</strong>
          </div>
        </div>

        <div class="col-md-4">
          <div class="border rounded p-3 bg-danger bg-opacity-10">
            <small class="text-muted d-block">Urgente</small>
            <strong><%= number_with_delimiter(@meta.urgente_km) %> Km</strong>
          </div>
        </div>

      </div>

    </div>

    <% if @meta.cantidad_meta_horas.present? %>

      <!-- Configuración por Horas -->
      <div class="mb-4">

        <h5 class="border-bottom pb-2">
          ⏱️ Configuración por Horas de Motor
        </h5>

        <div class="row">

          <div class="col-md-4">
            <div class="border rounded p-3 bg-light">
              <small class="text-muted d-block">Meta</small>
              <strong><%= number_with_delimiter(@meta.cantidad_meta_horas) %> Horas</strong>
            </div>
          </div>

          <div class="col-md-4">
            <div class="border rounded p-3 bg-warning bg-opacity-10">
              <small class="text-muted d-block">Alerta</small>
              <strong><%= number_with_delimiter(@meta.alerta_horas) %> Horas</strong>
            </div>
          </div>

          <div class="col-md-4">
            <div class="border rounded p-3 bg-danger bg-opacity-10">
              <small class="text-muted d-block">Urgente</small>
              <strong><%= number_with_delimiter(@meta.urgente_horas) %> Horas</strong>
            </div>
          </div>

        </div>

      </div>

    <% end %>

    <div class="mt-4">

      <strong>Color de la Meta</strong>
      <br>

      <span class="badge fs-6 px-3 py-2"
            style="background-color:<%= @meta.color %>; color:white;">
        <%= @meta.color.capitalize %>
      </span>

    </div>

  </div>

</div>

<div class="mt-3 d-flex gap-2">

  <%= link_to "Editar",
      edit_meta_path(@meta),
      class: "btn btn-warning" %>

  <%= link_to "Volver",
      metas_path,
      class: "btn btn-secondary" %>

  <%= button_to "Eliminar",
      meta_path(@meta),
      method: :delete,
      class: "btn btn-danger",
      form: {
        data: {
          turbo_confirm: "¿Está seguro de eliminar esta meta?"
        }
      } %>

</div>