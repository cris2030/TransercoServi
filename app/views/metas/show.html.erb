<div class="card shadow-sm border-0">

  <div class="card-header text-white"
       style="background-color:<%= @meta.color %>">

    <h4 class="mb-0">
      <%= @meta.nombre %>
    </h4>

  </div>

  <div class="card-body">

    <p>
      <strong>Cantidad Meta:</strong>
      <%= @meta.cantidad_meta %> Km
    </p>

    <p>
      <strong>Alertar cuando falten:</strong>
      <%= @meta.alerta_km %> Km
    </p>

    <p>
      <strong>Urgente cuando supere:</strong>
      <%= @meta.urgente_km %> Km
    </p>

    <p>
      <strong>Color:</strong>

      <span
        class="badge"
        style="background-color:<%= @meta.color %>; color:white;">
        <%= @meta.color.capitalize %>
      </span>
    </p>

  </div>

</div>

<div class="mt-3 d-flex gap-2">

  <%= link_to "Editar",
      edit_meta_path(@meta),
      class: "btn btn-warning" %>

  <%= link_to "Volver",
      metas_path,
      class: "btn btn-secondary" %>

  <%= button_to "Eliminar",
      meta_path(@meta),
      method: :delete,
      class: "btn btn-danger",
      form: {
        data: {
          turbo_confirm: "¿Está seguro de eliminar esta meta?"
        }
      } %>

</div>