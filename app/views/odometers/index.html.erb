<h1 class="mb-4">
  Odómetros de Unidades
</h1>

<div class="card shadow-sm border-0">

  <div class="card-body p-0">

    <div class="table-responsive">

      <table class="table table-hover table-striped align-middle mb-0">

        <thead class="table-dark">
          <tr>
            <th>Unidad</th>
            <th>Odómetro ECM</th>
            <th>Odómetro GPS</th>
          </tr>
        </thead>

        <tbody>

          <% @odometers[:OdometersInfo]&.each do |item| %>

            <% unit_name = item[:UnitName]%>

            <tr>

              <td>
                <strong>
                  <%= unit_name %>
                </strong>
              </td>

              <td>
                <%= number_with_delimiter(item[:OdometerEcm]) %> km
              </td>

              <td>
                <%= number_with_delimiter(item[:OdometerGps]) %> km
              </td>

            </tr>

          <% end %>

        </tbody>

      </table>

    </div>

  </div>

</div>