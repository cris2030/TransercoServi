<% content_for :title, "Editar Servicio" %>

<div class="container py-5">

  <div class="row justify-content-center">

    <div class="col-lg-8">

      <div class="mb-4">

        <h1 class="fw-bold text-warning">
          <i class="bi bi-pencil-square"></i>
          Editar Servicio
        </h1>

        <p class="text-muted mb-0">
          Actualice la información del servicio registrado.
        </p>

      </div>

      <%= render "form", servicio: @servicio %>

      <div class="text-center mt-4">

        <%= link_to @servicio,
              class: "btn btn-outline-info me-2" do %>

          <i class="bi bi-eye"></i>
          Ver Servicio

        <% end %>

        <%= link_to servicios_path,
              class: "btn btn-outline-secondary" do %>

          <i class="bi bi-list"></i>
          Listado de Servicios

        <% end %>

      </div>

    </div>

  </div>

</div>