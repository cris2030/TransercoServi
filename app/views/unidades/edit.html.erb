<% content_for :title, "Editar Unidad" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="mb-4">
        <h1 class="fw-bold text-warning">
          <i class="bi bi-pencil-square"></i>
          Editar Unidad
        </h1>

        <p class="text-muted mb-0">
          Actualice la información de la unidad seleccionada.
        </p>
      </div>

      <%= render "form", unidad: @unidad %>

      <div class="mt-3 text-center">
        <%= link_to @unidad, class: "btn btn-outline-info me-2" do %>
          <i class="bi bi-eye"></i>
          Ver Unidad
        <% end %>

        <%= link_to unidades_path, class: "btn btn-outline-secondary" do %>
          <i class="bi bi-list"></i>
          Listado de Unidades
        <% end %>
      </div>

    </div>
  </div>
</div>