<% content_for :title, "Unidad" %>

<% if notice.present? %>
  <div class="alert alert-success py-2">
    <%= notice %>
  </div>
<% end %>

<div class="card shadow-sm border-0">

  <!-- HEADER -->
  <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">

    <div>
      <h5 class="mb-0">
        Unidad <%= @unidad.codigo %>
      </h5>

      <small class="text-light">
        ID: <%= @unidad.unitID %>
      </small>
    </div>

    <span class="badge bg-secondary fs-6">
      <%= @unidad.placa %>
    </span>

  </div>

  <!-- BODY -->
  <div class="card-body">

    <div class="row g-3">

      <!-- INFO GENERAL -->
      <div class="col-md-6">

        <div class="p-3 border rounded bg-light h-100">

          <h6 class="text-muted mb-3">Información General</h6>

          <p class="mb-2">
            <strong>Código:</strong> <%= @unidad.codigo %>
          </p>

          <p class="mb-2">
            <strong>Placa:</strong> <%= @unidad.placa %>
          </p>

          <p class="mb-0">
            <strong>Unit ID:</strong> <%= @unidad.unitID %>
          </p>

        </div>

      </div>

      <!-- METAS ASIGNADAS -->
      <div class="col-md-6">

        <div class="p-3 border rounded bg-light h-100">

          <h6 class="text-muted mb-3">Meta Asignada</h6>

          <% if @unidad.meta.present? %>

            <span class="badge mb-2"
                  style="background-color:<%= @unidad.meta.color %>; color:#fff;">
              <%= @unidad.meta.nombre %>
            </span>

            <p class="mb-1">
              <strong>Inicio:</strong>
              <%= @unidad.meta.kilometraje_inicio %> km
            </p>

            <p class="mb-0">
              <strong>Final:</strong>
              <%= @unidad.meta.kilometraje_final %> km
            </p>

          <% else %>

            <div class="alert alert-warning mb-0">
              Esta unidad no tiene meta asignada
            </div>

          <% end %>

        </div>

      </div>

    </div>

  </div>

</div>

<!-- ACCIONES -->
<div class="mt-3 d-flex gap-2">

  <%= link_to "Editar",
      edit_unidad_path(@unidad),
      class: "btn btn-warning" %>

  <%= link_to "Volver",
      unidades_path,
      class: "btn btn-secondary" %>

  <%= button_to "Eliminar",
      @unidad,
      method: :delete,
      class: "btn btn-danger",
      form: { data: { turbo_confirm: "¿Seguro que deseas eliminar esta unidad?" } } %>

</div>